# Banking Data Platform — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────
BANKING_DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/banking_platform
BANKING_DB_HOST=localhost
BANKING_DB_PORT=5432
BANKING_DB_NAME=banking_platform
BANKING_DB_USER=postgres
BANKING_DB_PASSWORD=postgres

# ── dbt ───────────────────────────────────────────────────────
DBT_ENV=dev          # dev | prod  (controls PII masking)
DBT_PROFILES_DIR=./dbt_project

# ── Airflow ───────────────────────────────────────────────────
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# ── Pipeline ──────────────────────────────────────────────────
PIPELINE_ENV=dev
USD_TO_CAD_RATE=1.36
DORMANCY_THRESHOLD_DAYS=730
FINTRAC_THRESHOLD_CAD=10000

# ── Alerts ────────────────────────────────────────────────────
ALERT_EMAIL=data-alerts@yourbank.internal
DQ_SCORE_MINIMUM=70
